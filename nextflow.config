// Nextflow flags
nextflow.enable.configProcessNamesValidation = false
nextflow.enable.moduleBinaries = true

// Unscoped options
cleanup   = false
workDir   = "nf-work"

// Global default params, used in configs
params {
    // pipeline parameters
    help            = false
    datasets        = null
    specie          = 'auto'
    default_specie  = null

    // output parameters
    publish_mode        = 'link'
    output_dir          = "results"
    monochrome_logs     = false
    trace_report_suffix = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
}
profiles {
    // Standard profile for execution at FARM cluster
    standard {
        // pipeline parameters
        params {
            wl_basedir = "/nfs/cellgeni/STAR/whitelists"
            human_reference = "/nfs/cellgeni/STAR/human/2020A/index"
            mouse_reference = "/nfs/cellgeni/STAR/mouse/2020A/index"
        }
       // Configuring LSF job submission parameters for each process
        executor {
            name           = 'lsf'
            perJobMemLimit = true
        }
        // Singularity environment parameters
        singularity {
            enabled     = true
            autoMounts  = true
            cacheDir    = '/nfs/cellgeni/singularity/images/'
            runOptions  = '-B /lustre,/nfs'
            pullTimeout = '100m'
        }
    }

    // Development profile for local execution
    development {
        // pipeline parameters
        params {
            wl_basedir = "/nfs/cellgeni/STAR/whitelists"
            human_reference = "/home/ubuntu/nf-reprocessing-public-10x/references/human/2020A/index/index"
            mouse_reference = "/home/ubuntu/nf-reprocessing-public-10x/references/mouse/2020A/index/index"
        }
        // Configuring local execution parameters for development
        executor {
            name = 'local'
        }
        // Singularity environment parameters for local execution
        docker {
            enabled = true
        }
    }
}

// Configure process parameters
process {
    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) || task.attempt == 1 ? 'retry' : 'finish' }
    maxRetries    = 3
}

// Capturing Nextflow log files into a 'reports' directory
timeline {
    enabled = true
    file    = "reports/execution_timeline_${params.trace_report_suffix}.html"
}
report {
    enabled = true
    file    = "reports/execution_report_${params.trace_report_suffix}.html"
}
trace {
    enabled = true
    file    = "reports/execution_trace_${params.trace_report_suffix}.txt"
}
dag {
    enabled = true
    file    = "reports/pipeline_dag_${params.trace_report_suffix}.html"
}

// Set environment variable to use the new syntax parser
env {
    NXF_SYNTAX_PARSER = "v2"
}

// Load module configurations
includeConfig 'configs/reprocess10x_sra2fastq.config'
includeConfig 'configs/reprocess10x_bam2fastq.config'
includeConfig 'configs/reprocess10x_loaddata.config'
includeConfig 'configs/reprocess10x_parsemetadata.config'
includeConfig 'configs/reprocess10x_starsolo.config'
includeConfig 'configs/reprocess10x_mappingqc.config'

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

manifest {
    name            = 'cellgeni/nf-reprocessing-public-10x'
    author          = "CellgenI Team"
    homePage        = 'https://github.com/cellgeni/nf-reprocessing-public-10x'
    description     = "Pipeline to load and process public 10x datasets"
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.2'
    version         = '23-263'
}
