process {
    withName: '.*REPROCESS10X_BAM2FASTQ' {
        queue = 'normal'
        cpus = 16
        memory = '4 GB'
        publishDir = [
            path: { "${params.output_dir}/raw/${meta.dataset_id}/${meta.sample_id}" },
            mode: params.publish_mode,
            pattern: '*.fastq.gz'
        ]
    }
}