        //         } else if ( filepath ==~ /.*\.bam/ ) {
        //             return "bam/${meta.sample_id}/$filepath"
        //         } else if ( filepath != "versions.yml" ) {
        //             return "sra/${meta.sample_id}/$filepath"
        //         } else {
        //             return null
        //         }
        //     }
        // ]
    }
}